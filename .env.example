# CABANA — environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored; NEVER commit real keys. Do not add secrets to this file.
#
# Canonical backend is the cloud Supabase project "cabanadatabase"
# (ref: rpzaeqoqcaxxavltgvpe). For local Docker work, run `supabase status`
# and swap these to the printed local values (the http://127.0.0.1:54321 stack);
# keep the client (VITE_*) and server values pointing at the SAME project.

# ── Server runtime (NOT VITE_-prefixed; read via process.env on the SSR /
#    serverless function). REQUIRED at request time on the deploy target: every
#    server action (auth-middleware / optional-auth-middleware) reads
#    SUPABASE_URL + SUPABASE_PUBLISHABLE_KEY, and post-media signed URLs
#    (getPostMediaUrls via supabaseAdmin, src/integrations/supabase/client.server.ts)
#    read SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY — the admin factory THROWS if
#    the service-role key is absent, so private post media won't render without it.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Service role bypasses RLS — server-only, must NEVER be exposed to the client
# (no VITE_ prefix, never imported into a client module).
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_jwt...

# ── Client (VITE_-prefixed; inlined into the browser bundle at build time).
#    Publishable/anon key + project id only — never a secret here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# ── Cloudflare Stream (video uploads/playback) — server-only, NEVER
#    VITE_-prefixed and never imported into a client module. The API token is
#    used exclusively by server actions (`stream-actions.ts`) and the webhook
#    secret only by the /api/webhooks/stream route. Names are standardized in
#    STREAM_ENV_VARS (src/lib/cabana-stream.ts).
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_STREAM_TOKEN=your_stream_api_token_with_stream_edit_permission
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=customer-xxxxxxxx.cloudflarestream.com
# Returned by Cloudflare when the webhook URL is registered (PUT .../stream/webhook);
# not needed for local dev (webhooks cannot reach localhost — polling covers it).
CLOUDFLARE_STREAM_WEBHOOK_SECRET=returned_when_registering_the_webhook
# STREAM_SIGNING_KEY_ID is reserved for a future local-signing upgrade and is
# intentionally UNUSED in v1 — no code reads it; do not add it here.
