# CABANA — production smoke-test credentials. Copy to `.env.smoke` and fill in.
# `.env.smoke` is gitignored (matched by the `.env*` rule); NEVER commit real
# credentials. This template is the only tracked file (see `!.env.smoke.example`).
#
# Used by: `bun run smoke:prod` (scripts/smoke-prod.ts) — post-deploy smoke
# checks against production (cabanagrp.com + the cloud Supabase backend).
# The script uses ONLY the publishable key + real user sessions (never the
# service role) — it tests exactly what real users can see.

# ── User A: an EXISTING creator account (ideally also admin — the DB-STATE
#    admin-finance assertions SKIP if A is not an admin). Must already have a
#    creator_profiles row. Its posts/uploads are created with a `smoke_` prefix
#    and cleaned up after every run.
SMOKE_USER_A_EMAIL=
SMOKE_USER_A_PASSWORD=

# ── User B: a THROWAWAY member account (account_type "member"). If it doesn't
#    exist yet, run `bun run smoke:prod --setup` once to sign it up through the
#    real signup path. If email confirmation is enabled in the Supabase project,
#    the script will tell you — confirm B's email once, then re-run normally.
SMOKE_USER_B_EMAIL=
SMOKE_USER_B_PASSWORD=

# ── Cloud Supabase project (cabanadatabase, ref rpzaeqoqcaxxavltgvpe).
#    PUBLISHABLE key only — the script aborts if it detects a service-role key.
SMOKE_SUPABASE_URL=https://rpzaeqoqcaxxavltgvpe.supabase.co
SMOKE_SUPABASE_KEY=sb_publishable_dmQqaKvywWnBscgqGDfs7w_hPGqfhNH

# ── Optional: deployed app origin for the DEPLOY-FRESHNESS check.
# SMOKE_BASE_URL=https://cabanagrp.com
