# Supabase local CLI state
supabase/.branches
supabase/.temp

# Reconciliation backups: point-in-time data dumps (contain PII + a bcrypt
# password hash from auth.users) — keep locally, never commit.
supabase/reconcile/backups/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
AGENTS.md
.vercel
.env*
# Keep the secret-free templates tracked (these negations must follow the .env* rule
# above — last matching rule wins — or they get re-ignored). `.env.smoke` (real
# smoke-test credentials for scripts/smoke-prod.ts) stays ignored via .env*.
!.env.example
!.env.smoke.example

# Claude Code local (per-user) settings — never commit; shared agent defs under
# .claude/agents/ stay track-able on purpose.
.claude/settings.local.json
